// Обработчик POST /search
// Поиск по коду модулей конфигурации.
//
// Тело запроса: JSON {"query": "...", "limit": 50}
// Ответ: JSON {"matches": [{module, line, context}, ...], "total": N}
//
// Выполняет регистронезависимый поиск подстроки во всех модулях конфигурации:
// общие модули, справочники, документы, обработки, отчёты, регистры.
// Для каждого совпадения возвращает имя модуля, номер строки и контекст (+-2 строки).
//
// ПРИМЕЧАНИЕ: Функции ПрочитатьJSON/СтрокаJSON определены в query.bsl.
// Функция ПолучитьКодМодуля определена в module.bsl.
// В реальном расширении они должны находиться в общем модуле.

Функция SearchPOST(Запрос)

    ТелоJSON = Запрос.ПолучитьТелоКакСтроку();
    Параметры = ПрочитатьJSON(ТелоJSON);

    СтрокаПоиска = Параметры.query;
    Если ПустаяСтрока(СтрокаПоиска) Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""query is required""}");
        Возврат Ответ;
    КонецЕсли;

    Лимит = 50;
    Если Параметры.Свойство("limit") И Параметры.limit > 0 Тогда
        Лимит = Мин(Параметры.limit, 500);
    КонецЕсли;

    Результаты = Новый Массив;

    // Коллекции метаданных, содержащие модули
    МассивКоллекций = Новый Массив;
    МассивКоллекций.Добавить(Метаданные.ОбщиеМодули);
    МассивКоллекций.Добавить(Метаданные.Справочники);
    МассивКоллекций.Добавить(Метаданные.Документы);
    МассивКоллекций.Добавить(Метаданные.Обработки);
    МассивКоллекций.Добавить(Метаданные.Отчеты);
    МассивКоллекций.Добавить(Метаданные.РегистрыСведений);
    МассивКоллекций.Добавить(Метаданные.РегистрыНакопления);

    Для Каждого Коллекция Из МассивКоллекций Цикл
        Если Результаты.Количество() >= Лимит Тогда
            Прервать;
        КонецЕсли;

        Для Каждого ОбъектМД Из Коллекция Цикл
            Если Результаты.Количество() >= Лимит Тогда
                Прервать;
            КонецЕсли;

            // Общие модули — один модуль на объект
            Если ТипЗнч(ОбъектМД) = Тип("ОбъектМетаданных: ОбщийМодуль") Тогда
                ИмяМодуля = "CommonModule." + ОбъектМД.Имя;
                Попытка
                    КодМодуля = ОбъектМД.ПолучитьМодуль().ПолучитьТекст();
                Исключение
                    Продолжить;
                КонецПопытки;
                НайтиВКоде(КодМодуля, СтрокаПоиска, ИмяМодуля, Результаты, Лимит);
            Иначе
                // Объекты с несколькими видами модулей
                ТипОбъекта = СтрЗаменить(Строка(ТипЗнч(ОбъектМД)), "ОбъектМетаданных: ", "");

                МассивМодулей = Новый Массив;
                МассивМодулей.Добавить("ObjectModule");
                МассивМодулей.Добавить("ManagerModule");

                Для Каждого ВидМодуля Из МассивМодулей Цикл
                    Если Результаты.Количество() >= Лимит Тогда
                        Прервать;
                    КонецЕсли;

                    КодМодуля = ПолучитьКодМодуля(ОбъектМД, ВидМодуля);
                    Если КодМодуля = Неопределено Тогда
                        Продолжить;
                    КонецЕсли;

                    ИмяМодуля = ТипОбъекта + "." + ОбъектМД.Имя + "." + ВидМодуля;
                    НайтиВКоде(КодМодуля, СтрокаПоиска, ИмяМодуля, Результаты, Лимит);
                КонецЦикла;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("matches", Результаты);
    Результат.Вставить("total", Результаты.Количество());

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;

КонецФункции

// НайтиВКоде — ищет подстроку в тексте модуля (регистронезависимо).
// Для каждого совпадения добавляет в массив Результаты структуру
// с именем модуля, номером строки и контекстом (+-2 строки).
Процедура НайтиВКоде(КодМодуля, СтрокаПоиска, ИмяМодуля, Результаты, Лимит)

    Если ПустаяСтрока(КодМодуля) Тогда
        Возврат;
    КонецЕсли;

    Строки = СтрРазделить(КодМодуля, Символы.ПС);
    ПоискВРег = ВРег(СтрокаПоиска);

    Для НомерСтроки = 1 По Строки.Количество() Цикл
        Если Результаты.Количество() >= Лимит Тогда
            Возврат;
        КонецЕсли;

        ТекСтрока = Строки[НомерСтроки - 1];
        Если СтрНайти(ВРег(ТекСтрока), ПоискВРег) > 0 Тогда
            // Контекст: текущая строка +-2 строки
            НачИндекс = Макс(1, НомерСтроки - 2);
            КонИндекс = Мин(Строки.Количество(), НомерСтроки + 2);
            КонтекстСтроки = Новый Массив;
            Для Инд = НачИндекс По КонИндекс Цикл
                КонтекстСтроки.Добавить(Строки[Инд - 1]);
            КонецЦикла;

            Совпадение = Новый Структура;
            Совпадение.Вставить("module", ИмяМодуля);
            Совпадение.Вставить("line", НомерСтроки);
            Совпадение.Вставить("context", СтрСоединить(КонтекстСтроки, Символы.ПС));
            Результаты.Добавить(Совпадение);
        КонецЕсли;
    КонецЦикла;

КонецПроцедуры
