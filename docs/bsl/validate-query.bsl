// Обработчик POST /validate-query
// Проверяет синтаксис запроса на языке запросов 1С без выполнения.
//
// Тело запроса: JSON {"query": "ВЫБРАТЬ ..."}
// Ответ: JSON {"valid": true/false, "errors": ["...", ...]}
//
// Использует СхемаЗапроса для разбора текста запроса.
// Если запрос корректен — valid=true, errors пустой.
// Если есть синтаксические ошибки — valid=false, errors содержит описания ошибок.
//
// ПРИМЕЧАНИЕ: Функции ПрочитатьJSON/СтрокаJSON определены в query.bsl.
// В реальном расширении они должны находиться в общем модуле.
//
// ВАЖНО: СхемаЗапроса доступна начиная с платформы 8.3.5.

Функция ValidateQueryPOST(Запрос)

    ТелоJSON = Запрос.ПолучитьТелоКакСтроку();
    Параметры = ПрочитатьJSON(ТелоJSON);

    ТекстЗапроса = Параметры.query;
    Если ПустаяСтрока(ТекстЗапроса) Тогда
        Ответ = Новый HTTPСервисОтвет(400);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""query is required""}");
        Возврат Ответ;
    КонецЕсли;

    Ошибки = Новый Массив;

    Попытка
        СхемаЗапроса = Новый СхемаЗапроса;
        СхемаЗапроса.УстановитьТекстЗапроса(ТекстЗапроса);

        // Проверяем, что текст запроса восстанавливается из схемы
        // Это подтверждает корректность разбора
        ВосстановленныйТекст = СхемаЗапроса.ПолучитьТекстЗапроса();

        Результат = Новый Структура;
        Результат.Вставить("valid", Истина);
        Результат.Вставить("errors", Ошибки);
    Исключение
        Результат = Новый Структура;
        Результат.Вставить("valid", Ложь);
        Ошибки.Добавить(ОписаниеОшибки());
        Результат.Вставить("errors", Ошибки);
    КонецПопытки;

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;

КонецФункции
