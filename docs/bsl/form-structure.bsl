// Обработчик GET /form/{type}/{name}
// Возвращает структуру основной формы объекта метаданных:
// элементы, команды формы и обработчики событий.
//
// URL параметры:
//   type — тип объекта: Catalog, Document, DataProcessor, Report и т.д.
//   name — имя объекта метаданных
//
// Ответ: JSON с полями Имя, Заголовок, Элементы, Команды, Обработчики
//
// ПРИМЕЧАНИЕ: Функции СтрокаJSON и НайтиМетаданныеПоТипуИИмени определены
// в query.bsl и object.bsl соответственно.
// В реальном расширении они должны находиться в общем модуле.

Функция FormGET(Запрос)
    ТипОбъекта = Запрос.ПараметрыURL["type"];
    ИмяОбъекта = Запрос.ПараметрыURL["name"];

    ОбъектМД = НайтиМетаданныеПоТипуИИмени(ТипОбъекта, ИмяОбъекта);
    Если ОбъектМД = Неопределено Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""Object not found""}");
        Возврат Ответ;
    КонецЕсли;

    // Получаем основную форму (или первую доступную)
    Форма = ПолучитьОсновнуюФорму(ОбъектМД);
    Если Форма = Неопределено Тогда
        Ответ = Новый HTTPСервисОтвет(404);
        Ответ.УстановитьТелоИзСтроки("{""error"": ""Form not found""}");
        Возврат Ответ;
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("Имя", Форма.Имя);
    Результат.Вставить("Заголовок", Форма.Синоним);

    // Элементы формы
    Элементы = Новый Массив;
    Для Каждого Элемент Из Форма.Элементы Цикл
        ОписаниеЭлемента = Новый Структура;
        ОписаниеЭлемента.Вставить("Имя", Элемент.Имя);
        ОписаниеЭлемента.Вставить("Тип", Строка(ТипЗнч(Элемент)));

        Попытка
            ОписаниеЭлемента.Вставить("Заголовок", Элемент.Заголовок);
        Исключение
            ОписаниеЭлемента.Вставить("Заголовок", "");
        КонецПопытки;

        Попытка
            ОписаниеЭлемента.Вставить("ПутьКДанным", Строка(Элемент.ПутьКДанным));
        Исключение
            ОписаниеЭлемента.Вставить("ПутьКДанным", "");
        КонецПопытки;

        Элементы.Добавить(ОписаниеЭлемента);
    КонецЦикла;
    Результат.Вставить("Элементы", Элементы);

    // Команды формы
    Команды = Новый Массив;
    Для Каждого Команда Из Форма.Команды Цикл
        ОписаниеКоманды = Новый Структура;
        ОписаниеКоманды.Вставить("Имя", Команда.Имя);
        ОписаниеКоманды.Вставить("Действие", Команда.Действие);
        Команды.Добавить(ОписаниеКоманды);
    КонецЦикла;
    Результат.Вставить("Команды", Команды);

    // Обработчики событий формы
    Обработчики = Новый Массив;
    МассивСобытий = Новый Массив;
    МассивСобытий.Добавить("ПриОткрытии");
    МассивСобытий.Добавить("ПриСозданииНаСервере");
    МассивСобытий.Добавить("ПередЗаписью");
    МассивСобытий.Добавить("ПриЗаписиНаСервере");
    МассивСобытий.Добавить("ПослеЗаписиНаСервере");
    МассивСобытий.Добавить("ПередЗакрытием");
    МассивСобытий.Добавить("ОбработкаОповещения");
    МассивСобытий.Добавить("ОбработкаНавигационнойСсылки");
    МассивСобытий.Добавить("ОбработкаВыбора");

    Для Каждого ИмяСобытия Из МассивСобытий Цикл
        Попытка
            ИмяОбработчика = Форма[ИмяСобытия];
            Если Не ПустаяСтрока(ИмяОбработчика) Тогда
                ОписаниеОбработчика = Новый Структура;
                ОписаниеОбработчика.Вставить("Событие", ИмяСобытия);
                ОписаниеОбработчика.Вставить("Обработчик", ИмяОбработчика);
                Обработчики.Добавить(ОписаниеОбработчика);
            КонецЕсли;
        Исключение
            // Событие не поддерживается данным типом формы
            Продолжить;
        КонецПопытки;
    КонецЦикла;
    Результат.Вставить("Обработчики", Обработчики);

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрокаJSON(Результат));
    Возврат Ответ;
КонецФункции

// ПолучитьОсновнуюФорму — возвращает основную форму объекта метаданных.
// Сначала пытается найти ОсновнуюФормуОбъекта / ОсновнуюФормуСписка / ОсновнуюФормуВыбора,
// если не задана — берёт первую форму из коллекции.
// Возвращает Неопределено если формы отсутствуют.
Функция ПолучитьОсновнуюФорму(ОбъектМД)

    // Попытка получить назначенную основную форму
    МассивОсновных = Новый Массив;
    МассивОсновных.Добавить("ОсновнаяФормаОбъекта");
    МассивОсновных.Добавить("ОсновнаяФормаСписка");
    МассивОсновных.Добавить("ОсновнаяФормаВыбора");
    МассивОсновных.Добавить("ОсновнаяФорма");

    Для Каждого ИмяСвойства Из МассивОсновных Цикл
        Попытка
            ОсновнаяФорма = ОбъектМД[ИмяСвойства];
            Если ОсновнаяФорма <> Неопределено Тогда
                Возврат ОсновнаяФорма;
            КонецЕсли;
        Исключение
            Продолжить;
        КонецПопытки;
    КонецЦикла;

    // Основная форма не назначена — берём первую из коллекции
    Попытка
        Если ОбъектМД.Формы.Количество() > 0 Тогда
            Для Каждого ФормаМД Из ОбъектМД.Формы Цикл
                Возврат ФормаМД;
            КонецЦикла;
        КонецЕсли;
    Исключение
        // У объекта нет коллекции форм
    КонецПопытки;

    Возврат Неопределено;
КонецФункции
